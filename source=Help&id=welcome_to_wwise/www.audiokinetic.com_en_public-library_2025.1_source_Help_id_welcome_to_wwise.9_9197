<style>
.main-content h1 {text-transform:none;} .warning-redirect {background:rgba(0,174,238,0.25); border:1px solid #009FDA; border-radius:5px; padding:10px 1em; margin-bottom:1.5em; font-size: 150%;}
</style>
<script>
    const BUFFER_PADDING = 20;


    var toc,
        tocTopOffset,
        navRight,
        footerContainer,
        currentNavHelper;

    var topMenuHeight = 0;
    var additionalTopOffset = 0;
    var initialToCTopOffset = 0;
    var lastWindowScroll = 0;
    var footerIntersectionObserver = new IntersectionObserver(unstickToC);
    var isFooterVisible = false;

    function mutationObserverCallback(mutations) {
        setInitialTopOffset()
        setAdditionalTopOffset();
        var [newTop, newPosition] = placeToC();
        resizeToC(newTop, newPosition);
        toc.fixToCHeight()
    }

    function triggerSearch() {
        term = encodeURIComponent($("#banner_search").val());
        source = "Help";
        version = "2025.1.9_9197";
        
        window.location.href = '/en/search/?term=' + term + '&source=' + source + '&version=' + version;
    }

    function unstickToC(entries, observer) {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                isFooterVisible = true;
            } else {
                isFooterVisible = false;
            }
        })
    }

    function setInitialTopOffset() {
        initialToCTopOffset = (toc.element.offset().top) + parseInt(toc.element.css('padding-top'));
        topMenuHeight = $(reactMenuRoot).height()
    }

    function setAdditionalTopOffset() {
        var verticalScroll = window.scrollY;
        var elevatorHeight = toc.elevator.height();
        var whereToCFinishes = verticalScroll + initialToCTopOffset + BUFFER_PADDING + elevatorHeight;
        var whereFooterStarts = $(footerContainer).offset().top;
        additionalTopOffset = whereToCFinishes - whereFooterStarts;
    }

    function getOffset() {
        return initialToCTopOffset - additionalTopOffset;
    }

    // The height of the footer that is visible.
    // Starts at 0, and when we're scrolling past it, it becomes greater than 0.
    function getVisibleFooterHeight() {
        var pixels = (window.scrollY + window.innerHeight) - $(footerContainer).offset().top;
        return pixels >= 0 ? pixels : 0;
    }

    function resizeToC(tocTop, tocPosition) {
        if (tocTop > 0 && tocPosition == 'fixed') {
            $(toc.elevator).add(navRight).css({
                height: window.innerHeight - tocTop - getVisibleFooterHeight(),
                overflowY: 'auto'
            })
        } else {
            $(toc.elevator).add(navRight).css({
                height: window.innerHeight - $(toc.element).offset().top,
                overflowY: 'auto'
            })
        }
    }

    function placeToC() {
        var top = 0;
        var position = 'fixed';

        if (window.scrollY + topMenuHeight >= initialToCTopOffset) {
            top = topMenuHeight + BUFFER_PADDING
            position = 'fixed';
        } else {
            position = 'relative';
        }

        // Set the value to the element:
        $(toc.elevator).add(navRight).css({
            position: position,
            top: top
        });

        return [top, position];
    }

    function initializeHtmlNodeHeight() {
        var bufferToAvoidSeeingPastTheFooter = 300;
        $('html').css('height', $(document).height() - bufferToAvoidSeeingPastTheFooter);
    }

    function scrollToElement(selector, animate) {
        const elementToScrollTo = document.querySelector(selector)
        const negativeOffset = isMobile() ? 200 : 100 // otherwise it scolls too far down
        const offsetToScrollTo = elementToScrollTo.offsetTop + negativeOffset
        setTimeout(()=>{
            window.scrollTo({
                top: offsetToScrollTo,
                behavior: animate ? 'smooth' : 'instant'
            })
        })
    }

    function debounce(func, delay) {
        let timeoutId;

        return function () {
            clearTimeout(timeoutId);

            timeoutId = setTimeout(() => {
                func.apply(this, arguments);
            }, delay);
        };
    }

    function updatenavRightScroll() {
        const currentScroll = window.scrollY;
        const currentTitleElement = $(currentNavHelper.find('a').attr('href'));
        let isScrollDown;
        let nextTitleElement;

        // We scrolled down
        if (currentScroll >= lastWindowScroll) {
            nextTitleElement = $(currentNavHelper.next().find('a').attr('href'));
            isScrollDown = true;
        } else {
            nextTitleElement = $(currentNavHelper.prev().find('a').attr('href'));
            isScrollDown = false;
        }

        if (nextTitleElement.length > 0) {
            // Determine the currently visible titles
            const viewportTop = $(window).scrollTop();
            const viewportBottom = viewportTop + $(window).height();
            
            const nextTitleElementTop = nextTitleElement.offset().top;
            const nextTitleElementBottom = nextTitleElementTop + nextTitleElement.outerHeight();
            const nextTitleVisible = nextTitleElementTop > viewportTop && nextTitleElementBottom < viewportBottom;

            const currentTitleElementTop = currentTitleElement.offset().top;
            const currentTitleElementBottom = currentTitleElementTop + currentTitleElement.outerHeight();
            const currentTitleElementVisible = currentTitleElementTop > viewportTop && currentTitleElementBottom < viewportBottom;
            const currentTitleElementBelowViewport = currentTitleElementTop > viewportBottom;
            if (nextTitleVisible || (isScrollDown == false && currentTitleElementBelowViewport)) {
                $("#nav-right-sections li.active").removeClass('active');
                currentNavHelper = isScrollDown ? currentNavHelper.next() : currentNavHelper.prev();
                currentNavHelper.addClass('active');
            }
        }

        lastWindowScroll = currentScroll;
    }


    var topMenuRootMutationObserver;

    $(document).ready(function(){
        // Create an observer instance
        if (isDesktop()) {
            topMenuRootMutationObserver = new MutationObserver(mutationObserverCallback);
        }

        $.ajaxSetup ({cache: false});

        if (isDesktop()) {
            $(window).on('scroll', debounce(function() {
                setAdditionalTopOffset();
                var [newTop, newPosition] = placeToC();
                resizeToC(newTop, newPosition);
            }, 20));
        }


        // Copy to clipboard
        $("#share_doc_button").click(function(){
            navigator.clipboard.writeText($(this).data('copy'));
            icon = $(this).find('.material-icons');
            icon.html("check");
            setTimeout(function(){
                icon.html("link");
            }, 2500);
        });

        // activate tooltip
        $(".aktip").qtip($.extend({}, qtipDefaults, {}));

        $('#ddVersions').AwesomeSelect({
            dropdownClass : 'search-filter-input search-filter-dropdown', 
            choiceClass : 'search-filter-dropdown-choice', 
            selectClass : 'search-filter-select select-down',
            includeFirstOption : true
        });
        $('#ddVersions').change(function(){
            if ( $(this).val() ) window.location = $(this).val();
        });
        $('#banner_submit').click(function() {
            triggerSearch();
        });
        $('#banner_search').keyup(function(e) {
            if (e.keyCode == 13) {
                triggerSearch();
            }
        });

        // Do this immediately:
        initializeHtmlNodeHeight();
        // And after some time, to make sure everything that needed to take up some space had the time to initialize:
        setTimeout(() => {
            initializeHtmlNodeHeight();
        }, 1500)

        toc = new AK_ToC({
            nodes_url:"/en/public-library/2025.1.9_9197/",
            toc_id:"#div-toc",
            toc_child_id:"#tocchild",
            content_id:"#div-content",
            item_button_class:".toclink"
        });

        navRight = $("#nav-right-elevator");

        if (isDesktop()) {
            mutationObserverCallback(); // initialize things
        }

        //Put the default english title in th H1 when empty
        var sourceTitle = $('.toc-header').html();
        if(sourceTitle == '&nbsp;'){
            $('.toc-header').text($('.toccurrentlink').text());
        }

                window.setTimeout(function() {
            var container = $('#div-toc'),
            scrollTo = $('#div-toc a[href$="welcome_to_wwise"]');

            container.scrollTop(
              scrollTo.offset().top - container.offset().top + container.scrollTop() - 90
            );
        }, 0);
        


        // ddSelect generates it's own html
        // style the last 4 digits of dropdown menu
        $('.search-filter-dropdown-choice').html(function(_,txt) {
            return txt.replace(/(\.[0-9]{1,4}$)/, "<span class='minor'>$&</span>");
        });

        // style select options in the dropdown
        $('.awesome-popup p').each(function( i ) {
            var n = $(this).text().length;
            if ( n > 14 ) {
                  $(this).addClass('long-name');
            }
            $(this).html(function(_,txt) {
                return txt.replace(/(\.[0-9]{1,4}$)/, "<span class='minor'>$&</span>");
            });
        });
        
        // I dunno why this fixes the re-sizing issue with text that has class="minor", but it does...I know it's lazy coding and I'm sorry! - Claudia
        $('.awesome-popup p').on('click', function() {
            $('.search-filter-dropdown-choice').html(function(_,txt) {
                return txt.replace(/(\.[0-9]{1,4}$)/, "<span class='minor'>$&</span>");
            });
        });

        // Collapse toc sidebar menu
        $('#toc-btn').click(function() {
            $('#div-toc').toggleClass('collapse-toc');
            $('#div-toc').toggleClass('m-collapse-toc');
            $('#toc-btn').toggleClass('collapsed');
            $('#results-and-nav-wrap').toggleClass('collapse-result');
        });

        $('#nav-btn').click(function() {
            $('#nav-right').toggleClass('collapse-nav-right');
            $('#nav-btn').toggleClass('collapsed');
        });
    
        // remove inline table width attribute
        $("table").removeAttr( "width" );
        $("col").removeAttr( "width" );

        // replace down arrow icon on dropdown menu
        $('#ddVersions_AwesomeSelect').find('.material-icons').html('arrow_drop_down');

        // Redesign HTML replacement for older versions of documentation
        // Should do nothing on new versions, only meant to affect older versions
        // iconNote = $('img[src*="Note.gif"], img[src*="note.png"]').replaceWith('<i class="material-icons i-msg i-note">info_outline</i>');
        // iconTip = $('img[src*="/Tip.gif"], img[src*="=Tip.gif"], img[src*="=tip.png"]').replaceWith('<i class="material-icons i-msg i-tip">info_outline</i>');
        // iconCaution = $('img[src*="Caution.gif"], img[src*="caution.png"]').replaceWith('<i class="material-icons i-msg i-caution">info_outline</i>');
        // iconWarning = $('img[src*="Warning.gif"], img[src*="warning.png"]').replaceWith('<i class="material-icons i-msg i-warning">info_outline</i>');
        iconNote = $('img[src*="Note.gif"], img[src*="note.png"]').replaceWith('<i class="material-symbols-outlined i-msg i-note">info</i>');
        iconTip = $('img[src*="/Tip.gif"], img[src*="=Tip.gif"], img[src*="=tip.png"]').replaceWith('<i class="material-symbols-outlined i-msg i-tip">check_circle</i>');
        iconCaution = $('img[src*="Caution.gif"], img[src*="caution.png"]').replaceWith('<i class="material-symbols-outlined i-msg i-caution">warning</i>');
        iconWarning = $('img[src*="Warning.gif"], img[src*="warning.png"]').replaceWith('<i class="material-symbols-outlined i-msg i-warning">dangerous</i>');
        iconTd = $(".i-msg").closest("td").addClass("icon-td");
        iconTd.removeAttr("width");
        messageTable = $(".icon-td").closest("table").addClass("message-table");
        messageTable.find("td").not("td:first-child, td:last-child").addClass("msg-td");
        messageTable.find("th").addClass("msg-th");
        messageTable.find("td:last-child").addClass("text-td");
        $(".msg-th").closest(".message-table").addClass("has-th");
        $(".i-note").closest("td").addClass("td-note");
        $(".i-tip").closest("td").addClass("td-tip");
        $(".i-caution").closest("td").addClass("td-caution");
        $(".i-warning").closest("td").addClass("td-warning");

        $('.mempage').prev('td').css('display','none');
        $('.memname').next('td').addClass('round-bracket-open');
        $('.paramname').next('td').addClass('round-bracket-close');

        $("#nav-right-sections a").click(function(){
            scrollToElement($(this).attr('href'), true);
            history.pushState(null,null, $(this).attr('href'));
            return false;
        });

        // Find the active element
        $("#nav-right-sections li").each(function(index) {
            if ($("#nav-right-sections li.active").length == 0) {
                const viewportTop = $(window).scrollTop();
                const viewportBottom = viewportTop + $(window).height();

                const titleElement = $($(this).find('a').attr('href'));
                
                const titleTop = titleElement.offset().top;
                const titleBottom = titleTop + titleElement.outerHeight();
                const isVisible = titleTop > viewportTop && titleBottom < viewportBottom;

                if (isVisible) {
                    currentNavHelper = $(this);
                    $(this).addClass('active');
                }
            }
        });

        $(window).on("scroll", updatenavRightScroll);
        updatenavRightScroll();
    });

    window.addEventListener('load', function () {
        // Is there a hash in the URL?
        if (window.location.hash) {
            scrollToElement(window.location.hash, false)
        }
    })

    $(window).resize(function () {
        // TODO: bonus point: handle cases where use changes aspect ratio, from desktop to mobile, or vice versa.
    })


</script>
</head>
<body>
    <div id="root">
    </div><!-- For the top menu -->

<div class="main-content-wrap  top-offset-jakhub-menu">
    &nbsp;     <div class="bootstrap">
    <div class="container-fluid doc-container"> 
            <div class="row top-banner top-banner-green  with-form ">
        <div class="banner-title-wrap">
            <div class="banner-title">
                <h1 style="text-transform:capitalize;">Wwise Help</h1>
<h2>Welcome to Wwise 2025.1.9</h2>                                <div class="banner-form">
                    <input id="banner_search" name="term" type="text" class="banner-form-input" placeholder="Search" value="">
                    <button id="banner_submit" type="submit" class="banner-form-submit banner-form-input">Search</button>
                </div>
                            </div>
        </div>
            </div>
            <div class="row main-content content-library">
            <div class="library-flex-container documentation-header">
                <!-- <div id="div-filters-expand">
                    <div class="expand-trigger flex-container" style="background-color: rgb(255, 255, 255);"><i class="material-icons" style="color: rgb(0, 159, 218);">&#xE315;</i></div>
                    <p></p>
                </div> -->
                <div id="div-filters">
                    <div class="filter-label">Version</div>
                    <div class="search-filters"><select id="ddVersions" class="search-filter-input search-filter-dropdown"><option value="../2025.1.9_9197/?source=Help&id=welcome_to_wwise" selected>2025.1.9.9197</option>
<option value="../2024.1.15_9110/?source=Help&id=welcome_to_wwise" >2024.1.15.9110</option>
<option value="../2026.1.1_9196/?source=Help&id=welcome_to_wwise" >2026.1.1.9196</option>
<option value="../2023.1.19_8928/?source=Help&id=welcome_to_wwise" >2023.1.19.8928</option>
<option value="../2022.1.19_8584/?source=Help&id=welcome_to_wwise" >2022.1.19.8584</option>
<option value="../2021.1.14_8108/?source=Help&id=welcome_to_wwise" >2021.1.14.8108</option>
</select></div>
                </div>
            </div>
        </div>
        <div class="row main-content content-library">
            <div class="library-flex-container documentation-body">
                <div id="toc-btn">
                    <i class="material-icons-outlined toc-collapse-btn">menu</i>
                </div>
